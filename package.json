{
  "name": "bistro-v4",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engine": {
    "node": "24.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "db:generate": "pnpm drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "pnpm drizzle-kit studio",
    "db:pull": "pnpm drizzle-kit pull",
    "build:cloudflare": "opennextjs-cloudflare build",
    "deploy:cloudflare": "opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "build-and-deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.9",
    "@opennextjs/cloudflare": "^1.20.1",
    "@xyflow/react": "^12.11.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.42.0",
    "gsap": "^3.15.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "perfect-freehand": "^1.2.3",
    "pg": "^8.22.0",
    "pg-cloudflare": "^1.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.11.2",
    "sharp": "^0.35.2",
    "three": "^0.185.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  }
}
